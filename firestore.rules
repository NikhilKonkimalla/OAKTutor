rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Allow public read/write through end of 2026.
      // Revisit before this date to add authentication-based rules.
      allow read, write: if request.time < timestamp.date(2026, 12, 31);
    }
  }
}
